# ─── Datenbank ────────────────────────────────────────────────────────────────
# Lokal (z.B. via Docker oder lokales PostgreSQL):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/boulderwall"

# Railway (wird automatisch gesetzt, wenn du die DB dort anlegst):
# DATABASE_URL="postgresql://..."

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Mindestens 32 Zeichen, zufällig generiert
JWT_SECRET="BITTE_AENDERN_min32zeichen_zufaellig_generiert_hier"

# Token-Gültigkeit
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
HOST="0.0.0.0"
NODE_ENV="development"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Expo Go / Dev: alle erlauben
# Produktion: deine tatsächliche Domain eintragen
CORS_ORIGIN="*"
